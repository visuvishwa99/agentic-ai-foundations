flowchart TD
    %% Base Styles

    %% Phase 1: DE Pipeline (Core Work)
    subgraph Phase_1 [Phase 1: The Core Data Pipeline]
        direction TB
        
        subgraph AWS [AWS Cloud Services]
            direction TB
            SNS["SNS FIFO<br/>Topic"]:::process
            SQS["SQS FIFO<br/>+ Filter"]:::process
            Pipes["EventBridge<br/>Pipes"]:::process
            Firehose["Kinesis<br/>Firehose"]:::process
            S3["S3 Bucket<br/>Partitioned"]:::storage
            
            SNS --> SQS
            SQS --> Pipes
            Pipes --> Firehose
            Firehose --> S3
        end

        subgraph Local [Local Docker Env]
            direction TB
            Simulator["Event Simulator<br/>(Python Script)"]:::user
            PySpark["PySpark ETL<br/>(Docker Container)"]:::process
            Postgres[("PostgreSQL<br/>Replica")]:::storage
            
            Simulator -->|Generates JSON Events| SNS
            PySpark -->|Reads JSON| S3
            PySpark -->|Loads Data| Postgres
        end
    end

    %% Tech Stack Mapping
    subgraph Stack_1 [Tech Stack - Phase 1]
        SimScript["<b>simulator/event_simulator.py</b><br/>Generates Mock Traffic"]:::user
        InfraScript["<b>infrastructure/template.yaml</b><br/>CloudFormation for AWS"]:::process
        SparkScript["<b>spark_jobs/etl_lexia_english.py</b><br/>PySpark Transformation"]:::process
        SQLScript["<b>infrastructure/init-postgres.sql</b><br/>Schema Definition"]:::storage
    end

    SimScript -.-> Simulator
    InfraScript -.-> AWS
    SparkScript -.-> PySpark
    SQLScript -.-> Postgres

    %% Global Style Block
    classDef logic fill:#5a3e00,stroke:#ffb300,stroke-width:2px,color:#fff
    classDef storage fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef process fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef user fill:#3a1a1a,stroke:#cc4444,stroke-width:2px,color:#fff
    classDef group fill:#2d3436,stroke:#dfe6e9,stroke-width:1px,color:#fff
