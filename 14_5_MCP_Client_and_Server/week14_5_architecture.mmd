graph TD
    %% Base Styles

    %% Nodes
    User([User]) -->|Query| Client[MCP Client / Agent]:::logic
    
    subgraph "Tech_Stack [Technology Stack]"
        direction TB
        ServerScript["<b>[2.0]_mcp_server.py</b><br/>Exposes Tools & Resources"]:::process
        ClientScript["<b>[1.0]_mcp_client.py</b><br/>Consumes Context"]:::logic
    end

    subgraph "MCP Ecosystem"
        direction TB
        Client -->|JSON-RPC Request| Transport["Transport Layer<br/>(stdio / SSE)"]:::group
        Transport -->|JSON-RPC Response| Server[MCP Server]:::process
        
        Server -->|Read| Files[(Local Files)]:::storage
        Server -->|Query| DB[(Database / Warehouse)]:::storage
    end

    %% Mappings
    ServerScript -.-> Server
    ClientScript -.-> Client

    %% Explanations
    Transport -- Like a Pipe/Socket --> User
    Server -- Like a Driver --> DB

    %% Global Style Block
    classDef logic fill:#5a3e00,stroke:#ffb300,stroke-width:2px,color:#fff
    classDef storage fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef process fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef user fill:#3a1a1a,stroke:#cc4444,stroke-width:2px,color:#fff
    classDef group fill:#2d3436,stroke:#dfe6e9,stroke-width:1px,color:#fff
