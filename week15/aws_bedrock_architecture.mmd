flowchart TD
    %% Top Level: Cost & Safety Infrastructure
    subgraph Cost_Safety [Phase 1 & 4: Cost & Safety Infrastructure]
        direction TB
        
        subgraph BudgetSystem [AWS Budgets Killswitch]
            direction TB
            Budget["<b>AWS Budgets</b><br/>($20 Limit)"]:::process
            BudgetRole["<b>AWS_Budgets_Action_Role</b><br/>(IAM Role)"]:::logic
            DenyPolicy["<b>Bedrock-Cost-Guardrail</b><br/>(Deny All Policy)"]:::storage
            AdminUser["<b>bedrock-admin</b><br/>(IAM User)"]:::user
            
            Budget -->|Triggers at 100%| BudgetRole
            BudgetRole -->|Attaches| DenyPolicy
            DenyPolicy -->|Blocks Access| AdminUser
        end

        subgraph MonitorSystem [CloudWatch Observability]
            direction TB
            CWLogs["<b>CloudWatch Logs</b><br/>(Agent Logs)"]:::storage
            MetricFilter["<b>Metric Filter</b><br/>(InputTokenCount > 0)"]:::logic
            CWAlarm["<b>CloudWatch Alarm</b><br/>(>50k tokens/5min)"]:::process
            SNSTopic["<b>SNS Topic</b><br/>(bedrock-token-alert)"]:::user
            
            CWLogs -->|Extracts| MetricFilter
            MetricFilter -->|Feeds Metric| CWAlarm
            CWAlarm -->|In Alarm| SNSTopic
        end
    end

    %% Bottom Level: Bedrock Agent Architecture
    subgraph Agent_Core [Phase 2 & 3: Bedrock Agent Architecture]
        direction TB
        
        UserMessage(("<b>User</b>")):::user
        SafetyGuardrail["<b>Bedrock Guardrails</b><br/>(PII & Content Filters)"]:::logic
        
        BedrockAgent["<b>Amazon Bedrock Agent</b><br/>(Claude 3.5 Sonnet)"]:::process
        
        AgentMemory[("<b>AgentCore Memory</b><br/>(Session Summarization)")]:::storage
        
        subgraph Action_Group [Action Group / The Hands]
            direction TB
            OpenAPI["<b>OpenAPI Schema</b><br/>(agent-api-schema.json)"]:::logic
            Lambda["<b>AWS Lambda</b><br/>(GetDateTimeFunction)"]:::process
            ResourcePolicy["<b>Resource-Based Policy</b><br/>(AllowBedrockInvoke)"]:::logic
            
            OpenAPI -.->|Defines Endpoints| Lambda
            ResourcePolicy -.->|Grants Permission| Lambda
        end
        
        UserMessage -->|Prompt| SafetyGuardrail
        SafetyGuardrail -->|Cleaned Prompt| BedrockAgent
        BedrockAgent <-->|Read/Write Context| AgentMemory
        BedrockAgent -->|Matches Intent| OpenAPI
        BedrockAgent -->|Invokes| Lambda
        Lambda -->|Returns JSON| BedrockAgent
        BedrockAgent -->|Response| SafetyGuardrail
        SafetyGuardrail -->|Cleaned Response| UserMessage
    end
    
    %% Cross-System Connections
    AdminUser -.->|Configures| BedrockAgent
    BedrockAgent -.->|Writes Logs| CWLogs

    %% Tech Stack & DE Mapping
    subgraph Tech_Stack [Technology Stack & DE Equivalents]
        direction TB
        AgentDE["<b>Bedrock Agent</b><br/>(like Airflow Orchestrator)"]:::process
        MemoryDE["<b>AgentCore Memory</b><br/>(like Redis/Memcached)"]:::storage
        LambdaDE["<b>AWS Lambda</b><br/>(like Spark Tasks/PythonOperator)"]:::process
        CWDE["<b>CloudWatch Logs/Alarms</b><br/>(like DataDog/Grafana)"]:::logic
    end

    AgentDE -.-> BedrockAgent
    MemoryDE -.-> AgentMemory
    LambdaDE -.-> Lambda
    CWDE -.-> MonitorSystem

    %% Base Styles

    %% Global Style Block
    classDef logic fill:#5a3e00,stroke:#ffb300,stroke-width:2px,color:#fff
    classDef storage fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef process fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef user fill:#3a1a1a,stroke:#cc4444,stroke-width:2px,color:#fff
    classDef group fill:#2d3436,stroke:#dfe6e9,stroke-width:1px,color:#fff
