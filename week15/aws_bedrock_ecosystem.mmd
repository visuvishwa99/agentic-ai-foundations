flowchart TD
    %% Base Styles

    User(("User")):::user
    
    subgraph Bedrock_Ecosystem [Amazon Bedrock Ecosystem]
        direction TB
        GuardrailIn["<b>Guardrails (Inbound)</b><br/>(like Great Expectations)"]:::logic
        GuardrailOut["<b>Guardrails (Outbound)</b><br/>(like Great Expectations)"]:::logic
        
        Agent["<b>AgentCore Orchestrator</b><br/>(like Airflow Scheduler)"]:::process
        Memory[("<b>Agent Memory</b><br/>(like Redis)")]:::storage
        
        KB[("<b>Knowledge Base</b><br/>(Vector DB / Data Warehouse)")]:::storage
        
        subgraph Action_Group [Action Group / The Hands]
            direction TB
            Schema["<b>OpenAPI Schema</b>"]:::logic
            Lambda["<b>AWS Lambda</b><br/>(like PythonOperator)"]:::process
            Schema -.-> Lambda
        end
        
        FM["<b>Foundation Model</b><br/>(Compute Engine / Spark)"]:::process
    end
    
    User -->|Prompt| GuardrailIn
    GuardrailIn -->|Clean Prompt| Agent
    
    Agent <-->|Read/Update Context| Memory
    Agent <-->|Query Facts| KB
    Agent <-->|Invoke Tool| Action_Group
    Agent <-->|Reasoning Core| FM
    
    Agent -->|Draft Answer| GuardrailOut
    GuardrailOut -->|Safe Response| User

    %% Global Style Block
    classDef logic fill:#5a3e00,stroke:#ffb300,stroke-width:2px,color:#fff
    classDef storage fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef process fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef user fill:#3a1a1a,stroke:#cc4444,stroke-width:2px,color:#fff
    classDef group fill:#2d3436,stroke:#dfe6e9,stroke-width:1px,color:#fff
