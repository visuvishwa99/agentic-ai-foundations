flowchart TD
    %% User Interaction
    User(["fa:fa-user User Query"]) --> Cache{"Semantic Cache"}
    
    %% Semantic Caching Layer
    Cache -- Match found --> Resp(["fa:fa-bolt Cached Response"])
    Cache -- No match --> Embed["Embedding Model<br/>(all-MiniLM-L6-v2)"]
    
    %% Vector Retrieval Layer
    subgraph Storage ["Vector Storage & Search"]
        direction LR
        FAISS["fa:fa-search FAISS Index"]
        Chroma["fa:fa-table ChromaDB"]
        Cosine["fa:fa-calculator Cosine Similarity"]
    end
    
    Embed --> Storage
    Storage --> Context["Retrieved Context"]
    
    %% RAG Pipeline Layer
    subgraph RAG ["Capstone RAG Pipeline"]
        LLM["fa:fa-robot LLM<br/>(Qwen 2.5 Coder)"]
        Prompt["Augmented Prompt"]
    end
    
    User -.-> Prompt
    Context --> Prompt
    Prompt --> LLM
    LLM --> Resp

    %% Technology Stack & Script Mapping
    subgraph Tech_Stack [Technology Stack & Script Mapping]
        Stack1["<b>Sentence Transformers</b><br/>Embedding Model (like Encoding in DE)"]
        Stack2["<b>FAISS & ChromaDB</b><br/>Vector DB (like Snowflake in DE)"]
        Stack3["<b>Qwen 2.5 Coder</b><br/>Generative LLM (like Transformation in DE)"]
        EmbedScript["<b>[1.1] [1.2] [1.3]</b><br/>Cosine, Embeddings, Vector"]
        DBScript["<b>[2.1] [2.2]</b><br/>FAISS & ChromaDB"]
        CacheScript["<b>[3.1]_semantic_cache.py</b><br/>Caching Layer"]
        RAGScript["<b>[4.1]_capstone_RAG.py</b><br/>Orchestrates RAG Pipeline"]
    end

    %% Visual Connections between Stack and Logic (Dash lines)
    Stack1 -.-> Embed
    Stack2 -.-> Storage
    Stack3 -.-> LLM

    %% Script-to-Architecture Mapping
    EmbedScript -.-> Embed
    DBScript -.-> Storage
    CacheScript -.-> Cache
    RAGScript -.-> RAG
    
    %% Apply Styles
    class User,Resp user
    class Cache,FAISS,Chroma storage
    class Embed,Cosine,Context,LLM process
    class Prompt logic
    
    style Tech_Stack fill:#fff,stroke:#2d3436,stroke-width:1px,color:#2d3436

    %% Global Style Block
    classDef logic fill:#2d3436,stroke:#dfe6e9,stroke-width:2px,color:#fff
    classDef storage fill:#0984e3,stroke:#74b9ff,stroke-width:2px,color:#fff
    classDef process fill:#6c5ce7,stroke:#a29bfe,stroke-width:2px,color:#fff
    classDef user fill:#00b894,stroke:#55efc4,stroke-width:2px,color:#fff
    classDef group fill:#f1f2f6,stroke:#2f3542,stroke-width:1px,color:#2d3436
