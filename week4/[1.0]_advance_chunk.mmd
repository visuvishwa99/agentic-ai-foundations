flowchart TD
    %% Ingestion Pipeline Subgraph
    subgraph Ingestion [Ingestion Pipeline]
        direction TB
        Input(["Input Document"]) --> DocType{"Document Type?"}
        
        DocType -->|PDF with tables| Parser1["LlamaParse"]
        DocType -->|Word/HTML| Parser2["Unstructured.io"]
        DocType -->|Image/Scan| Parser3["Unstructured + OCR"]
        
        Parser1 --> Struct["Structured Output"]
        Parser2 --> Struct
        Parser3 --> Struct
        
        Struct --> ElemType{"Element Type?"}
        
        ElemType -->|Text| C1["Text Chunks"]
        ElemType -->|Table| C2["Table as JSON/MD"]
        ElemType -->|Image| C3["Image + Caption"]
        
        C1 --> ChunkSys["Chunking System"]
        C2 --> ChunkSys
        C3 --> ChunkSys
        
        ChunkSys --> Embed["Embedded Chunks"]
        Embed --> VDB[("Vector Database")]
    end
    
    %% Retrieval flow Subgraph
    subgraph Retrieval_Flow [Retrieval Flow]
        direction TB
        Query(["User Query"]) --> Retrieve["Retrieval Engine"]
        VDB --> Retrieve
        Retrieve --> Result(["Relevant Context"])
    end

    %% Technology Stack & Script Mapping
    subgraph Tech_Stack [Technology Stack & Script Mapping]
        Stack1["<b>LlamaParse</b><br/>PDF Parsing (like OCR in DE)"]
        Stack2["<b>Unstructured.io</b><br/>Universal Parsing (like Ingestion in DE)"]
        Stack3["<b>ChromaDB</b><br/>Vector DB (like Snowflake in DE)"]
        AdvScript["<b>[1.1]_advancedchunkingsystem.py</b><br/>Advanced Parsing & Boosting"]
    end

    %% Visual Connections
    Stack1 -.-> Parser1
    Stack2 -.-> Parser2
    Stack3 -.-> VDB

    %% Script-to-Architecture Mapping
    AdvScript -.-> Ingestion

    %% Apply Styles
    class Input,Result,Query user
    class DocType,ElemType logic
    class Parser1,Parser2,Parser3,ChunkSys,Retrieve process
    class Struct,C1,C2,C3,Embed,VDB storage
    
    style Tech_Stack fill:#2d3436,stroke:#dfe6e9,stroke-width:1px,color:#fff

    %% Global Style Block
    classDef logic fill:#5a3e00,stroke:#ffb300,stroke-width:2px,color:#fff
    classDef storage fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef process fill:#1e3a5f,stroke:#4a9eda,stroke-width:2px,color:#fff
    classDef user fill:#3a1a1a,stroke:#cc4444,stroke-width:2px,color:#fff
    classDef group fill:#2d3436,stroke:#dfe6e9,stroke-width:1px,color:#fff
