flowchart TD
    %% Global Graph Configuration
    
    %% --- Section 1: Technology Stack Reference ---
    subgraph Tech_Stack [System Technology Stack]
        Stack1["<b>LlamaParse</b><br/>PDF Parsing (like OCR in DE)"]:::process
        Stack2["<b>Unstructured.io</b><br/>Universal Parsing (like Ingestion in DE)"]:::process
        Stack3["<b>ChromaDB</b><br/>Vector DB (like Snowflake in DE)"]:::storage
    end

    %% --- Section 2: Ingestion Pipeline ---
    subgraph Ingestion [Ingestion Pipeline]
        Input([Input Document]):::user --> DocType{Document Type?}:::logic
        
        DocType -->|PDF with tables| Parser1[LlamaParse]:::process
        DocType -->|Word/HTML| Parser2[Unstructured.io]:::process
        DocType -->|Image/Scan| Parser3[Unstructured + OCR]:::process
        
        Parser1 --> Struct[Structured Output]:::storage
        Parser2 --> Struct
        Parser3 --> Struct
        
        Struct --> ElemType{Element Type?}:::logic
        
        ElemType -->|Text| C1[Text Chunks]:::storage
        ElemType -->|Table| C2[Table as JSON/MD]:::storage
        ElemType -->|Image| C3[Image + Caption]:::storage
        
        C1 --> ChunkSys[Chunking System]:::process
        C2 --> ChunkSys
        C3 --> ChunkSys
        
        ChunkSys --> Embed[Embedded Chunks]:::storage
        Embed --> VDB[(Vector Database)]:::storage
    end
    
    %% --- Section 3: Retrieval ---
    subgraph Retrieval_Flow [Retrieval Flow]
        Query([User Query]):::user --> Retrieve[Retrieval Engine]:::process
        VDB --> Retrieve
        Retrieve --> Result([Relevant Context]):::user
    end

    %% Visual Connections between Stack and Logic
    Stack1 -.-> Parser1
    Stack2 -.-> Parser2
    Stack3 -.-> VDB

    %% Styling to match Subgraphs
    style Tech_Stack fill:#fff,stroke:#2d3436,stroke-width:1px,color:#2d3436
    style Ingestion fill:#f1f2f6,stroke:#2f3542,stroke-width:1px,color:#2d3436
    style Retrieval_Flow fill:#f1f2f6,stroke:#2f3542,stroke-width:1px,color:#2d3436

    %% Global Style Block
    classDef logic fill:#2d3436,stroke:#dfe6e9,stroke-width:2px,color:#fff
    classDef storage fill:#0984e3,stroke:#74b9ff,stroke-width:2px,color:#fff
    classDef process fill:#6c5ce7,stroke:#a29bfe,stroke-width:2px,color:#fff
    classDef user fill:#00b894,stroke:#55efc4,stroke-width:2px,color:#fff
    classDef group fill:#f1f2f6,stroke:#2f3542,stroke-width:1px,color:#2d3436