flowchart TD
    %% Input Layer
    Config["Configuration<br/>(size, overlap, model)"]
    Doc["Raw Document Text"]
    
    %% Strategies Subgraph
    subgraph Strategies ["Chunking Strategies"]
        direction TB
        Fixed["Fixed Size<br/>(Sliding Window)"]
        Sentence["Sentence Based<br/>(Boundary Aware)"]
        Section["Section Based<br/>(Header Aware)"]
        Semantic["Semantic Similarity<br/>(Meaning Based)"]
    end
    
    %% Processing Subgraph
    subgraph Processing ["Processing Engine"]
        direction TB
        Validate["Validation Engine<br/>(Quality Scoring)"]
        Embed["Embedding Engine<br/>(Sentence Transformers)"]
    end
    
    Retrieve["Retrieval Test<br/>(Finding Answers)"]
    Output["Visual Scorecard<br/>(Performance Report)"]

    %% Connections
    Config --> Strategies
    Doc --> Strategies
    
    Strategies --> Validate
    Strategies --> Embed
    
    Validate --> Output
    Embed --> Retrieve
    Retrieve --> Output

    %% Technology Stack & Script Mapping
    subgraph Tech_Stack [Technology Stack & Script Mapping]
        Stack1["<b>Sentence Transformers</b><br/>Embeddings (like Encoding in DE)"]
        Stack2["<b>Numpy & Pandas</b><br/>Data Handling (like Pandas in DE)"]
        Stack3["<b>Matplotlib</b><br/>Visual Scorecard (like Tableau in DE)"]
        ChunkScript["<b>[0.1]_chunk_system.py</b><br/>Chunking & Validation"]
    end

    %% Visual Connections
    Stack1 -.-> Embed
    Stack2 -.-> Validate
    Stack3 -.-> Output

    %% Script-to-Architecture Mapping
    ChunkScript -.-> Strategies
    ChunkScript -.-> Processing

    %% Apply Styles
    class Config,Retrieve logic
    class Doc,Output user
    class Fixed,Sentence,Section,Semantic,Validate,Embed process

    style Tech_Stack fill:#fff,stroke:#2d3436,stroke-width:1px,color:#2d3436

    %% Global Style Block
    classDef logic fill:#2d3436,stroke:#dfe6e9,stroke-width:2px,color:#fff
    classDef storage fill:#0984e3,stroke:#74b9ff,stroke-width:2px,color:#fff
    classDef process fill:#6c5ce7,stroke:#a29bfe,stroke-width:2px,color:#fff
    classDef user fill:#00b894,stroke:#55efc4,stroke-width:2px,color:#fff
    classDef group fill:#f1f2f6,stroke:#2f3542,stroke-width:1px,color:#2d3436
